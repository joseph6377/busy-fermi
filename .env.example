# Keep true until a paid live session is deliberately started.
MOCK_RUNPOD=true

RUNPOD_API_KEY=
RUNPOD_ENDPOINT_ID=
CACHED_MODEL_ID=

# Optional fallback for models that cannot use RunPod Cached Models.
RUNPOD_DATACENTER_ID=
RUNPOD_S3_ENDPOINT=
RUNPOD_S3_ACCESS_KEY_ID=
RUNPOD_S3_SECRET_ACCESS_KEY=

HF_TOKEN=
CIVITAI_API_TOKEN=

PORT=3000
HOST=127.0.0.1
OUTPUT_DIR=outputs
LOCAL_MODEL_DIR=local_models
MODEL_MANIFEST=model_manifest.json
SESSION_STATE=session_state.json
MAX_REQUEST_MB=8
MAX_WIDTH=2048
MAX_HEIGHT=2048
MAX_STEPS=60
MAX_BATCH_SIZE=1
JOB_TIMEOUT_SECONDS=600
POLL_INTERVAL_MAX_MS=5000
MAX_MODEL_DOWNLOAD_GB=20
TEMP_VOLUME_SAFETY_GB=2
AUTO_DELETE_VOLUME_AFTER_SUCCESS=true
